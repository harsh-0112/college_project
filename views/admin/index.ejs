<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Complaint Management</title>
  <link rel="stylesheet" href="/styles/main.css">
  <!-- <script src="https://unpkg.com/axios/dist/axios.min.js"></script> -->
</head>

<body>
  <div class="container">
    <h1>Admin Complaints Portal</h1>
    <ul id="postsList">
      <% listItems.forEach(item=> { %>
        <li>
          <h2>
            <%=item.title%>
          </h2>
          <small>
            <%=item.created_at %>
          </small>
          <p>
            <%=item.category_name%>
          </p>
          <!-- <small>By: =item.user_id </small> -->
           <div>
            <h4><u>Admin Remark</u> 
              <% if(item.status_name) {%>
              (<%= item.status_name %>)</h4>
              <% } %>
            <small>As per <%= item.remark_date %></small>
            <% if(item.remark_text){ %>
              <h4><%= item.remark_text %></h4>
              <% } %>
          </div>
          <a class="remark" href="/remark/<%= item.complaint_id %>">Add Remark</a>
          <a class="delete" href="/api/posts/delete/<%= item.id %>">Delete</a>
        </li>
        <% }); %>
    </ul>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>

</html>